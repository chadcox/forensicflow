{
  "name": "forensicflow-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ci": "PLAYWRIGHT_USE_WEBSERVER=0 PLAYWRIGHT_BASE_URL=http://web:5173 playwright test --reporter=line",
    "test:e2e:backend": "PLAYWRIGHT_USE_WEBSERVER=0 PLAYWRIGHT_BASE_URL=http://web:5173 PLAYWRIGHT_BACKEND_E2E=1 playwright test e2e/backend-analyst-flow.spec.ts --reporter=line"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~6.0.3",
    "vite": "^6.0.0"
  }
}
